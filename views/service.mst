<!DOCTYPE html>
<html>
    <head>
        <title>{{name}}</title>
        <link rel="stylesheet" href="/styles.css" />
    </head>
    <body>
        <h1>{{name}}</h1>
        <p>{{description}}</p>
        <ol>
            {{#instances}}
                <li><a href="{{address}}" class="dull">{{address}}</a></li>
            {{/instances}}
        </ol>
        <p>Return to <a href="/services">all services</a></p>
    </body>
</html>